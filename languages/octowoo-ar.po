msgstr "امتداد PHP مطلوب غير موجود: %s"

#: src/Core/Validator.php
msgid "Memory limit %s may be too low. Recommended: 256M or higher."
msgstr "حد الذاكرة %s منخفض قد يتسبب في مشاكل. الموصى به: 256M أو أعلى."

#: src/Core/Validator.php
msgid "Cannot connect to OpenCart database: %s"
msgstr "تعذّر الاتصال بقاعدة بيانات OpenCart: %s"

